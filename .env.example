# Docker Compose 環境變數（複製為 .env 後填入實際值）

# 從 registry 拉取的 image（CI 建置完成後設定）
FRONTEND_IMAGE=ghcr.io/inhouseaccman/mycloset-frontend:latest
BACKEND_IMAGE=ghcr.io/inhouseaccman/mycloset-backend:latest

# MySQL（需與 configs/secrets.ini [database] 區段一致）
MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=closet_management
MYSQL_USER=closet
MYSQL_PASSWORD=

# MySQL image（國內 VPS 建議使用鏡像加速）
MYSQL_IMAGE=docker.m.daocloud.io/library/mysql:8.0
