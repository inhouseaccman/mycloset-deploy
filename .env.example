# Docker Compose 環境變數（複製為 .env 後填入實際值）

FRONTEND_IMAGE=mycloset-frontend:latest
BACKEND_IMAGE=mycloset-backend:latest
NGINX_IMAGE=nginx:1.27-alpine

# MySQL（需與 configs/secrets.ini [database] 區段一致）
MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=closet_management
MYSQL_USER=closet
MYSQL_PASSWORD=
MYSQL_IMAGE=mysql:8.0
