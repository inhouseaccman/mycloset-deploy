# Production：在 build server 建置映像，再串流至 VPS（VPS 不 docker build）
# 注意：Frontend 的 BASE_URL 會 bake 進映像，必須與 nginx 對外網址一致

DEPLOY_ENV=production
PLATFORM=linux/amd64

# Build server（192.168.100.11）；SSH 別名見專案根目錄 .ssh/config
BUILD_SSH_HOST=closet-build
BUILD_REMOTE_DIR=/opt/build/closet-management
# SSH_CONFIG_BUILD=   # 預設 <repo>/.ssh/config

# Git repos（deploy 一律 git pull，禁止 rsync 本機原始碼）
GIT_BRANCH=master
BACKEND_REPO=https://github.com/inhouseaccman/mycloset-backend.git
FRONTEND_REPO=https://github.com/inhouseaccman/mycloset-frontend.git
DEPLOY_REPO=https://github.com/inhouseaccman/mycloset-deploy.git

# 同域名 API：前端請求 https://kayakicloset.vip/api/...
BASE_URL=https://kayakicloset.vip
URL_PREFIX=

FRONTEND_IMAGE=mycloset-frontend:latest
BACKEND_IMAGE=mycloset-backend:latest

SSH_HOST=mycloset-vps
REMOTE_DIR=/opt/deploy

# 公開值，需與 VPS /opt/deploy/configs/secrets.ini [google] client_id 一致
GOOGLE_CLIENT_ID=1099160565455-r2jlmn2i9ontham6nj3bh7jneunb4d7r.apps.googleusercontent.com

# 若未設 GOOGLE_CLIENT_ID，改從此檔讀取（可指向 production 專用 secrets）
SECRETS_INI=
